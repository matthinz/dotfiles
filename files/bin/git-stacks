#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require "yaml"
require "fileutils"

USAGE = <<~USAGE
  git-stacks — manage linear branch stacks (status, navigate, rebase, push).

  Reads a YAML file (MH-stacks.yml or .stacks.yml) describing one or more named
  linear stacks. The first entry in each list is the base and is never rebased
  or pushed; each subsequent entry is rebased onto its predecessor.

  Stacks file format:

    my-stack:
      - main               # base — not rebased, not pushed
      - feature/part-1     # rebased onto main
      - feature/part-2     # rebased onto feature/part-1

    another-stack:
      - main
      - feature/other

  Subcommands:

    git stacks                          # alias for `status`
    git stacks status                   # show parent/remote sync grid for the current stack
    git stacks diff [git-diff-args]     # diff the current branch against its parent
    git stacks rebase [opts]            # rebase each successor onto its predecessor
    git stacks cherry-pick [opts]       # reset child to parent, cherry-pick child's tip
    git stacks push [opts]              # push every non-base branch in the current stack
    git stacks first | last             # check out the first / last branch in the stack
    git stacks next  | prev             # check out the next / previous branch in the stack
    git stacks switch <stack>           # check out the first branch unique to <stack>
    git stacks test                     # build a scratch repo and self-test the script

  rebase / cherry-pick options:
    By default these only operate on the current branch (rebasing/cherry-picking
    it onto its parent in the stack). Pass --all to walk every successor.

    --dry-run            print destructive commands instead of running them
    --all                process every successor in the stack instead of just
                         the current branch

  push options:
    --dry-run            print the push commands instead of running them
    -f, --force          push with --force-with-lease
    --no-verify          pass --no-verify to every push
    --some-verify        first push runs hooks; subsequent pushes use --no-verify
USAGE

STACKS_FILE_CANDIDATES = %w[MH-stacks.yml .stacks.yml].freeze

REMOTE_LABELS = {
  pushed:    "⬆️  pushed",
  unpushed:  "📤 unpushed",
  behind:    "⬇️  behind",
  diverged:  "⚠️  diverged",
  no_remote: "❌ no remote",
  missing:   "❓ missing",
}.freeze

def print_branch_status_line(branch, list, idx, width)
  name_col = branch.ljust(width)
  unless branch_exists?(branch)
    puts "  #{name_col}  ❓ missing locally"
    return
  end
  parent_col =
    if idx.zero?
      " " * 12
    else
      parent = list[idx - 1]
      branch_exists?(parent) && branch_merged_into?(parent, branch) ? "✅ rebased " : "❌ behind  "
    end
  remote_col = REMOTE_LABELS[remote_status(branch)]
  puts "  #{name_col}  #{parent_col}  #{remote_col}"
end

def die(msg)
  warn "error: #{msg}"
  exit 1
end

def sh!(cmd)
  warn "+ #{cmd}"
  system(cmd) || raise("command failed: #{cmd}")
end

def maybe_sh!(cmd, dry_run:)
  if dry_run
    warn "+ [dry-run] #{cmd}"
  else
    sh!(cmd)
  end
end

def capture(cmd)
  out = `#{cmd}`
  raise "command failed: #{cmd}" unless $?.success?
  out.strip
end

def in_git_repo?
  system("git rev-parse --is-inside-work-tree > /dev/null 2>&1")
end

def working_tree_clean?
  `git status --porcelain`.strip.empty?
end

def current_branch
  capture("git rev-parse --abbrev-ref HEAD")
end

def branch_sha(branch)
  capture("git rev-parse #{branch}")
end

def stacks_search_roots
  roots = [capture("git rev-parse --show-toplevel")]
  main = capture("git worktree list --porcelain")
           .lines.find { |l| l.start_with?("worktree ") }
  roots << main.sub(/\Aworktree /, "").strip if main
  roots.uniq
end

def find_stacks_file
  stacks_search_roots.each do |root|
    STACKS_FILE_CANDIDATES.each do |name|
      path = File.join(root, name)
      return path if File.exist?(path)
    end
  end
  nil
end

def branch_merged_into?(child, parent)
  system("git merge-base --is-ancestor #{child} #{parent} > /dev/null 2>&1")
end

def branch_exists?(branch)
  system("git rev-parse --verify --quiet refs/heads/#{branch} > /dev/null 2>&1")
end

def remote_ref_exists?(branch)
  system("git rev-parse --verify --quiet refs/remotes/origin/#{branch} > /dev/null 2>&1")
end

def remote_status(branch)
  return :no_remote unless remote_ref_exists?(branch)
  local = branch_sha(branch)
  remote = capture("git rev-parse origin/#{branch}")
  return :pushed if local == remote
  local_ahead  = system("git merge-base --is-ancestor origin/#{branch} #{branch} > /dev/null 2>&1")
  local_behind = system("git merge-base --is-ancestor #{branch} origin/#{branch} > /dev/null 2>&1")
  return :unpushed if local_ahead && !local_behind
  return :behind   if local_behind && !local_ahead
  :diverged
end

def find_stack_containing(branch, stacks)
  matches = stacks.select { |_name, list| list.is_a?(Array) && list.include?(branch) }
  return nil if matches.empty?
  if matches.size > 1
    die("branch '#{branch}' appears in multiple stacks: #{matches.keys.join(', ')}")
  end
  name, list = matches.first
  [name, list]
end

def update_linear(start_branch, stack_list, opts)
  i = stack_list.index(start_branch)
  raise "start branch #{start_branch} not in stack list" unless i
  dry = opts[:dry_run]

  while i + 1 < stack_list.length
    parent = stack_list[i]
    child = stack_list[i + 1]

    saved_sha = (opts[:cherry_pick] && !dry) ? branch_sha(child) : nil
    sh!("git checkout #{child}")
    if opts[:cherry_pick]
      maybe_sh!("git reset --hard #{parent}", dry_run: dry)
      maybe_sh!("git cherry-pick #{saved_sha || '<saved-child-sha>'}", dry_run: dry)
    else
      maybe_sh!("git rebase #{parent}", dry_run: dry)
    end

    i += 1
    break unless opts[:all]
  end
end

def run_update(opts)
  die("not in a git repo") unless in_git_repo?
  die("working tree has uncommitted changes") unless working_tree_clean?

  stacks_file = find_stacks_file
  die("no stacks file found (looked for: #{STACKS_FILE_CANDIDATES.join(', ')})") unless stacks_file

  stacks = YAML.load_file(stacks_file)
  die("stacks file #{stacks_file} did not parse as a Hash") unless stacks.is_a?(Hash)

  original = current_branch
  found = find_stack_containing(original, stacks)
  die("current branch '#{original}' does not appear in #{stacks_file}") unless found
  _stack_name, stack_list = found

  if opts[:all]
    start_branch = original
  else
    orig_idx = stack_list.index(original)
    die("'#{original}' is the stack base; nothing to rebase onto (pass --all to rebase successors)") if orig_idx.zero?
    start_branch = stack_list[orig_idx - 1]
  end

  begin
    update_linear(start_branch, stack_list, opts)
    sh!("git checkout #{original}")
    warn "dry-run complete." if opts[:dry_run]
  rescue => e
    warn "error: #{e.message}"
    exit 1
  end
end

def push_cmd(force:, no_verify:)
  parts = ["git push"]
  parts << "--force-with-lease" if force
  parts << "--no-verify" if no_verify
  parts.join(" ")
end

def run_push(opts)
  die("not in a git repo") unless in_git_repo?
  die("--no-verify and --some-verify are mutually exclusive") if opts[:no_verify] && opts[:some_verify]

  stacks_file = find_stacks_file
  die("no stacks file found (looked for: #{STACKS_FILE_CANDIDATES.join(', ')})") unless stacks_file

  stacks = YAML.load_file(stacks_file)
  die("stacks file #{stacks_file} did not parse as a Hash") unless stacks.is_a?(Hash)

  original = current_branch
  found = find_stack_containing(original, stacks)
  die("current branch '#{original}' does not appear in #{stacks_file}") unless found
  _stack_name, stack_list = found

  to_push = stack_list[1..] || []
  if to_push.empty?
    warn "stack has no non-base branches to push."
    return
  end

  dry = opts[:dry_run]
  pushed_count = 0
  to_push.each do |branch|
    unless branch_exists?(branch)
      warn "skipping #{branch}: not present locally"
      next
    end
    no_verify =
      if opts[:no_verify]
        true
      elsif opts[:some_verify]
        pushed_count > 0
      else
        false
      end
    sh!("git checkout #{branch}")
    maybe_sh!(push_cmd(force: opts[:force], no_verify: no_verify), dry_run: dry)
    pushed_count += 1
  end

  sh!("git checkout #{original}") if current_branch != original
end

def run_nav(mode)
  die("not in a git repo") unless in_git_repo?

  stacks_file = find_stacks_file
  die("no stacks file found (looked for: #{STACKS_FILE_CANDIDATES.join(', ')})") unless stacks_file
  stacks = YAML.load_file(stacks_file)
  die("stacks file #{stacks_file} did not parse as a Hash") unless stacks.is_a?(Hash)

  branch = current_branch
  found = find_stack_containing(branch, stacks)
  die("current branch '#{branch}' does not appear in #{stacks_file}") unless found
  _name, list = found
  i = list.index(branch)

  target =
    case mode
    when :first
      die("already on first branch '#{branch}'") if i.zero?
      list.first
    when :last
      die("already on last branch '#{branch}'") if i == list.length - 1
      list.last
    when :next
      die("already on last branch '#{branch}'") if i == list.length - 1
      list[i + 1]
    when :prev
      die("already on first branch '#{branch}'") if i.zero?
      list[i - 1]
    end

  sh!("git checkout #{target}")
  print_branch_status_line(target, list, list.index(target), target.length)
end

def run_switch(stack_name)
  die("not in a git repo") unless in_git_repo?

  stacks_file = find_stacks_file
  die("no stacks file found (looked for: #{STACKS_FILE_CANDIDATES.join(', ')})") unless stacks_file
  stacks = YAML.load_file(stacks_file)
  die("stacks file #{stacks_file} did not parse as a Hash") unless stacks.is_a?(Hash)

  list = stacks[stack_name]
  unless list.is_a?(Array)
    available = stacks.keys.join(", ")
    die("unknown stack '#{stack_name}' (available: #{available})")
  end

  other_branches = stacks.each_with_object([]) do |(name, other_list), acc|
    next if name == stack_name
    acc.concat(other_list) if other_list.is_a?(Array)
  end

  branch = current_branch
  if list.include?(branch) && !other_branches.include?(branch)
    puts "🎯✨ already on stack '#{stack_name}' (branch '#{branch}') 🚀"
    return
  end

  target = list.find { |br| !other_branches.include?(br) }
  die("every branch in stack '#{stack_name}' also appears in another stack") unless target

  sh!("git checkout #{target}")
  width = list.map(&:length).max
  print_branch_status_line(target, list, list.index(target), width)
end

def run_status
  die("not in a git repo") unless in_git_repo?

  stacks_file = find_stacks_file
  die("no stacks file found (looked for: #{STACKS_FILE_CANDIDATES.join(', ')})") unless stacks_file

  stacks = YAML.load_file(stacks_file)
  die("stacks file #{stacks_file} did not parse as a Hash") unless stacks.is_a?(Hash)

  branch = current_branch
  found = find_stack_containing(branch, stacks)
  die("current branch '#{branch}' does not appear in #{stacks_file}") unless found
  name, list = found

  width = list.map(&:length).max
  puts "stack: #{name}"
  list.each_with_index do |br, i|
    print_branch_status_line(br, list, i, width)
  end
end

def run_diff(argv)
  if %w[-h --help].include?(argv.first)
    puts "Usage: git stacks diff [git-diff-args]"
    puts "Diff the current branch against its parent in the stack."
    puts "Any extra arguments (e.g. --name-only, --stat, -- path/) are passed to git diff."
    exit 0
  end

  die("not in a git repo") unless in_git_repo?

  stacks_file = find_stacks_file
  die("no stacks file found (looked for: #{STACKS_FILE_CANDIDATES.join(', ')})") unless stacks_file

  stacks = YAML.load_file(stacks_file)
  die("stacks file #{stacks_file} did not parse as a Hash") unless stacks.is_a?(Hash)

  branch = current_branch
  found = find_stack_containing(branch, stacks)
  die("current branch '#{branch}' does not appear in #{stacks_file}") unless found
  _name, list = found

  idx = list.index(branch)
  die("'#{branch}' is the stack base; nothing to diff against") if idx.zero?
  parent = list[idx - 1]
  die("parent branch '#{parent}' is missing locally") unless branch_exists?(parent)

  cmd = ["git", "diff", parent, *argv]
  warn "+ #{cmd.join(' ')}"
  system(*cmd) || exit($?.exitstatus || 1)
end

### Subcommand dispatch

def parse_rebase_opts(argv, label:)
  opts = { dry_run: false, cherry_pick: (label == "cherry-pick"), all: false }
  OptionParser.new do |o|
    o.banner = "Usage: git stacks #{label} [options]"
    o.on("--dry-run", "Print destructive commands instead of running them") { opts[:dry_run] = true }
    o.on("--all", "Process every successor in the stack instead of just the current branch") { opts[:all] = true }
    o.on("-h", "--help") { puts o; exit 0 }
  end.parse!(argv)
  die("unexpected arguments: #{argv.join(' ')}") unless argv.empty?
  opts
end

def parse_push_opts(argv)
  opts = { dry_run: false, force: false, no_verify: false, some_verify: false }
  OptionParser.new do |o|
    o.banner = "Usage: git stacks push [options]"
    o.on("--dry-run", "Print push commands instead of running them") { opts[:dry_run] = true }
    o.on("-f", "--force", "Push with --force-with-lease") { opts[:force] = true }
    o.on("--no-verify", "Pass --no-verify to every push") { opts[:no_verify] = true }
    o.on("--some-verify", "Run hooks on the first push only; --no-verify for the rest") { opts[:some_verify] = true }
    o.on("-h", "--help") { puts o; exit 0 }
  end.parse!(argv)
  die("unexpected arguments: #{argv.join(' ')}") unless argv.empty?
  opts
end

def parse_switch_opts(argv)
  OptionParser.new do |o|
    o.banner = "Usage: git stacks switch <stack>"
    o.on("-h", "--help") { puts o; exit 0 }
  end.parse!(argv)
  die("switch requires exactly one stack name argument") unless argv.length == 1
  argv.first
end

def parse_bare_opts(argv, label:)
  OptionParser.new do |o|
    o.banner = "Usage: git stacks #{label}"
    o.on("-h", "--help") { puts o; exit 0 }
  end.parse!(argv)
  die("unexpected arguments: #{argv.join(' ')}") unless argv.empty?
end

def dispatch(argv)
  if %w[-h --help help].include?(argv.first)
    puts USAGE
    exit 0
  end

  cmd = argv.shift || "status"
  case cmd
  when "status"
    parse_bare_opts(argv, label: "status")
    run_status
  when "diff"
    run_diff(argv)
  when "rebase"
    run_update(parse_rebase_opts(argv, label: "rebase"))
  when "cherry-pick"
    run_update(parse_rebase_opts(argv, label: "cherry-pick"))
  when "push"
    run_push(parse_push_opts(argv))
  when "first", "last", "next", "prev"
    parse_bare_opts(argv, label: cmd)
    run_nav(cmd.to_sym)
  when "switch"
    stack_name = parse_switch_opts(argv)
    run_switch(stack_name)
  when "test"
    parse_bare_opts(argv, label: "test")
    run_test_suite
  else
    warn "unknown subcommand: #{cmd}"
    warn ""
    warn USAGE
    exit 1
  end
end

### Self-test harness (test subcommand)

class TestRunner
  attr_reader :results, :scratch_root, :script_path

  def initialize(script_path, scratch_root)
    @script_path = script_path
    @scratch_root = scratch_root
    @results = []
  end

  def run(name, &block)
    dir = File.join(@scratch_root, name)
    FileUtils.mkdir_p(dir)
    Dir.chdir(dir) do
      setup_repo
      block.call(@script_path)
    end
    @results << [name, :pass, nil]
    warn "PASS  #{name}"
  rescue => e
    @results << [name, :fail, e.message]
    warn "FAIL  #{name}: #{e.message}"
  end

  def setup_repo
    sh_quiet("git init -q -b main")
    sh_quiet("git config user.email test@example.com")
    sh_quiet("git config user.name Test")
    File.write("init.txt", "init\n")
    sh_quiet("git add init.txt")
    sh_quiet("git commit -q -m init")
    File.write(".gitignore", ".stacks.yml\n")
    sh_quiet("git add .gitignore")
    sh_quiet("git commit -q -m gi")
  end

  def all_passed?
    @results.all? { |_, status, _| status == :pass }
  end
end

def sh_quiet(cmd)
  raise "command failed: #{cmd}" unless system(cmd, out: File::NULL, err: File::NULL)
end

def sh_capture(cmd)
  out = `#{cmd} 2>&1`
  [out, $?.success?]
end

def rev(branch)
  out = `git rev-parse #{branch} 2>/dev/null`.strip
  raise "no such branch: #{branch}" unless $?.success?
  out
end

def make_branch(name, parent, file, content)
  sh_quiet("git checkout -q -b #{name} #{parent}")
  File.write(file, content)
  sh_quiet("git add #{file}")
  sh_quiet("git commit -q -m #{name}")
end

def write_stacks(yaml)
  File.write(".stacks.yml", yaml)
end

def assert(cond, msg)
  raise msg unless cond
end

def setup_bare_remote_and_push_all(branches)
  remote_path = File.expand_path("../remote.git", Dir.pwd)
  FileUtils.rm_rf(remote_path)
  sh_quiet("git init -q --bare #{remote_path}")
  sh_quiet("git remote add origin #{remote_path}")
  sh_quiet("git push -q -u origin main")
  branches.each { |b| sh_quiet("git push -q -u origin #{b}") }
  remote_path
end

def install_counting_pre_push_hook(counter_path)
  hook = ".git/hooks/pre-push"
  File.write(hook, "#!/bin/sh\necho run >> #{counter_path}\nexit 0\n")
  File.chmod(0o755, hook)
end

def scenario_happy_path(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  make_branch("c", "b",    "c.txt", "c\n")
  sh_quiet("git checkout -q main")
  File.write("main2.txt", "v2\n")
  sh_quiet("git add main2.txt && git commit -q -m mainv2")
  main_sha = rev("main")
  write_stacks("s:\n  - main\n  - a\n  - b\n  - c\n")
  out, ok = sh_capture("ruby #{script} rebase --all")
  assert(ok, "script failed: #{out}")
  %w[a b c].each do |br|
    _, ancestor = sh_capture("git merge-base --is-ancestor #{main_sha} #{br}")
    assert(ancestor, "#{br} does not contain new main commit\n#{out}")
  end
end

def scenario_duplicate_branch(script)
  make_branch("a", "main", "a.txt", "a\n")
  sh_quiet("git checkout -q main")
  a_orig = rev("a")
  main_orig = rev("main")
  write_stacks("s1:\n  - main\n  - a\ns2:\n  - main\n  - a\n")
  out, ok = sh_capture("ruby #{script} rebase --all")
  assert(!ok, "expected failure for duplicate branch")
  assert(out.include?("appears in multiple stacks"), "missing expected error message in: #{out}")
  assert(rev("a") == a_orig, "a should not have changed")
  assert(rev("main") == main_orig, "main should not have changed")
end

def scenario_dry_run(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  sh_quiet("git checkout -q main")
  File.write("main2.txt", "v2\n")
  sh_quiet("git add main2.txt && git commit -q -m mainv2")
  a_orig = rev("a")
  b_orig = rev("b")
  write_stacks("s:\n  - main\n  - a\n  - b\n")
  out, ok = sh_capture("ruby #{script} rebase --all --dry-run")
  assert(ok, "dry-run failed: #{out}")
  assert(rev("a") == a_orig, "a should not have changed in dry-run")
  assert(rev("b") == b_orig, "b should not have changed in dry-run")
  assert(out.include?("[dry-run] git rebase"), "expected [dry-run] git rebase line in output:\n#{out}")
end

def current_head
  `git rev-parse --abbrev-ref HEAD`.strip
end

def scenario_nav(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  make_branch("c", "b",    "c.txt", "c\n")
  write_stacks("s:\n  - main\n  - a\n  - b\n  - c\n")

  sh_quiet("git checkout -q a")
  out, ok = sh_capture("ruby #{script} next")
  assert(ok, "next failed: #{out}")
  assert(current_head == "b", "expected b, got #{current_head}")

  out, ok = sh_capture("ruby #{script} next")
  assert(ok, "next to c failed: #{out}")
  assert(current_head == "c", "expected c, got #{current_head}")

  out, ok = sh_capture("ruby #{script} next")
  assert(!ok, "expected next at end to fail")
  assert(out.include?("already on last"), "missing error message: #{out}")

  out, ok = sh_capture("ruby #{script} prev")
  assert(ok && current_head == "b", "prev to b failed: head=#{current_head}, out=#{out}")
  sh_capture("ruby #{script} prev")
  sh_capture("ruby #{script} prev")
  assert(current_head == "main", "expected main after 3 prevs, got #{current_head}")
  out, ok = sh_capture("ruby #{script} prev")
  assert(!ok, "expected prev at first to fail")
  assert(out.include?("already on first"), "missing error message: #{out}")

  sh_quiet("git checkout -q c")
  out, ok = sh_capture("ruby #{script} first")
  assert(ok && current_head == "main", "first failed: head=#{current_head}, out=#{out}")
  out, ok = sh_capture("ruby #{script} first")
  assert(!ok, "expected first while on first to fail")
end

def scenario_last(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  make_branch("c", "b",    "c.txt", "c\n")
  write_stacks("s:\n  - main\n  - a\n  - b\n  - c\n")

  sh_quiet("git checkout -q a")
  out, ok = sh_capture("ruby #{script} last")
  assert(ok, "last failed: #{out}")
  assert(current_head == "c", "expected c, got #{current_head}")

  out, ok = sh_capture("ruby #{script} last")
  assert(!ok, "expected last while on last to fail")
  assert(out.include?("already on last"), "missing error message: #{out}")
end

def scenario_status(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  sh_quiet("git checkout -q main")
  File.write("main2.txt", "v2\n")
  sh_quiet("git add main2.txt && git commit -q -m mainv2")
  write_stacks("s:\n  - main\n  - a\n  - b\n")
  sh_quiet("git checkout -q a")

  out, ok = sh_capture("ruby #{script} status")
  assert(ok, "status (pre-rebase) failed: #{out}")
  assert(out.include?("❌ behind"),    "expected 'behind' for a before rebase:\n#{out}")
  assert(out.include?("❌ no remote"), "expected 'no remote' (no origin in test repo):\n#{out}")

  sh_quiet("git checkout -q main")
  _, ok = sh_capture("ruby #{script} rebase --all")
  assert(ok, "rebase run failed")
  sh_quiet("git checkout -q a")

  out, ok = sh_capture("ruby #{script} status")
  assert(ok, "status (post-rebase) failed: #{out}")
  assert(!out.include?("❌ behind"), "should be no 'behind' rows post-rebase:\n#{out}")
  assert(out.scan(/✅ rebased/).length >= 2, "expected 2+ rebased rows:\n#{out}")
end

def scenario_diff(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  write_stacks("s:\n  - main\n  - a\n  - b\n")
  sh_quiet("git checkout -q b")

  out, ok = sh_capture("ruby #{script} diff --name-only")
  assert(ok, "diff --name-only failed: #{out}")
  assert(out.include?("b.txt"), "expected b.txt in name-only diff:\n#{out}")
  assert(!out.include?("a.txt"), "a.txt should not appear (already in parent a):\n#{out}")

  # two-dot semantics: uncommitted working-tree edits are included
  File.write("a.txt", "a changed\n")
  out, ok = sh_capture("ruby #{script} diff --name-only")
  assert(ok, "diff after uncommitted edit failed: #{out}")
  assert(out.include?("a.txt"), "expected uncommitted a.txt edit to show (two-dot):\n#{out}")
  sh_quiet("git checkout -q -- a.txt")

  sh_quiet("git checkout -q main")
  out, ok = sh_capture("ruby #{script} diff")
  assert(!ok, "expected diff on stack base to fail")
  assert(out.include?("stack base"), "missing expected error message:\n#{out}")
end

def scenario_default_is_status(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  write_stacks("s:\n  - main\n  - a\n  - b\n")
  sh_quiet("git checkout -q a")
  a_orig = rev("a")
  b_orig = rev("b")
  out, ok = sh_capture("ruby #{script}")
  assert(ok, "default invocation failed: #{out}")
  assert(out.include?("stack: s"), "expected 'stack: s' in output:\n#{out}")
  assert(rev("a") == a_orig, "a changed under default invocation (should be read-only)")
  assert(rev("b") == b_orig, "b changed under default invocation (should be read-only)")
end

def scenario_push_dry_run(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  sh_quiet("git checkout -q main")
  setup_bare_remote_and_push_all(%w[a b])
  write_stacks("s:\n  - main\n  - a\n  - b\n")
  sh_quiet("git checkout -q a")
  out, ok = sh_capture("ruby #{script} push --dry-run -f")
  assert(ok, "push --dry-run failed: #{out}")
  assert(out.scan(/\[dry-run\] git push --force-with-lease/).length == 2,
         "expected 2 dry-run push lines:\n#{out}")
end

def scenario_push_force_updates_remote(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  sh_quiet("git checkout -q main")
  setup_bare_remote_and_push_all(%w[a b])

  sh_quiet("git checkout -q main")
  File.write("main2.txt", "v2\n")
  sh_quiet("git add main2.txt && git commit -q -m mainv2")
  write_stacks("s:\n  - main\n  - a\n  - b\n")

  _, ok = sh_capture("ruby #{script} rebase --all")
  assert(ok, "rebase failed")

  out, ok = sh_capture("ruby #{script} push -f")
  assert(ok, "push -f failed: #{out}")
  assert(rev("a") == rev("origin/a"), "origin/a not updated")
  assert(rev("b") == rev("origin/b"), "origin/b not updated")
end

def scenario_push_no_verify(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  sh_quiet("git checkout -q main")
  setup_bare_remote_and_push_all(%w[a b])

  sh_quiet("git checkout -q main")
  File.write("main2.txt", "v2\n")
  sh_quiet("git add main2.txt && git commit -q -m mainv2")
  write_stacks("s:\n  - main\n  - a\n  - b\n")
  _, ok = sh_capture("ruby #{script} rebase --all")
  assert(ok, "rebase failed")

  counter = File.expand_path("hook-count.log", Dir.pwd)
  File.delete(counter) if File.exist?(counter)
  install_counting_pre_push_hook(counter)

  out, ok = sh_capture("ruby #{script} push -f --no-verify")
  assert(ok, "push --no-verify failed: #{out}")
  assert(!File.exist?(counter), "pre-push hook ran despite --no-verify:\n#{File.exist?(counter) ? File.read(counter) : ''}")
end

def scenario_push_some_verify(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  make_branch("c", "b",    "c.txt", "c\n")
  sh_quiet("git checkout -q main")
  setup_bare_remote_and_push_all(%w[a b c])

  sh_quiet("git checkout -q main")
  File.write("main2.txt", "v2\n")
  sh_quiet("git add main2.txt && git commit -q -m mainv2")
  write_stacks("s:\n  - main\n  - a\n  - b\n  - c\n")
  _, ok = sh_capture("ruby #{script} rebase --all")
  assert(ok, "rebase failed")

  counter = File.expand_path("hook-count.log", Dir.pwd)
  File.delete(counter) if File.exist?(counter)
  install_counting_pre_push_hook(counter)

  out, ok = sh_capture("ruby #{script} push -f --some-verify")
  assert(ok, "push --some-verify failed: #{out}")
  lines = File.exist?(counter) ? File.read(counter).lines.count : 0
  assert(lines == 1, "expected pre-push hook to run exactly once with --some-verify, got #{lines}\n#{out}")
end

def scenario_rebase_default_is_current_branch(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  make_branch("c", "b",    "c.txt", "c\n")
  sh_quiet("git checkout -q a")
  File.write("a2.txt", "a2\n")
  sh_quiet("git add a2.txt && git commit -q -m a2")
  a_sha = rev("a")
  c_orig = rev("c")
  write_stacks("s:\n  - main\n  - a\n  - b\n  - c\n")

  sh_quiet("git checkout -q b")
  out, ok = sh_capture("ruby #{script} rebase")
  assert(ok, "bare rebase failed: #{out}")

  _, b_has_a = sh_capture("git merge-base --is-ancestor #{a_sha} b")
  assert(b_has_a, "b should contain new a commit:\n#{out}")
  assert(rev("c") == c_orig, "c should be untouched (was #{c_orig}, now #{rev('c')})")

  sh_quiet("git checkout -q main")
  out, ok = sh_capture("ruby #{script} rebase")
  assert(!ok, "expected bare rebase on base to fail")
  assert(out.include?("stack base"), "missing expected error in:\n#{out}")
end

def scenario_switch(script)
  make_branch("a", "main", "a.txt", "a\n")
  make_branch("b", "a",    "b.txt", "b\n")
  make_branch("x", "main", "x.txt", "x\n")
  make_branch("y", "x",    "y.txt", "y\n")
  write_stacks("s1:\n  - main\n  - a\n  - b\ns2:\n  - main\n  - x\n  - y\n")

  sh_quiet("git checkout -q main")
  out, ok = sh_capture("ruby #{script} switch s2")
  assert(ok, "switch s2 failed: #{out}")
  assert(current_head == "x", "expected x (first non-shared in s2), got #{current_head}")

  out, ok = sh_capture("ruby #{script} switch s2")
  assert(ok, "switch when already on stack failed: #{out}")
  assert(out.include?("🎯"), "expected fun emoji message when already on stack:\n#{out}")
  assert(current_head == "x", "head should not change when already on stack, got #{current_head}")

  sh_quiet("git checkout -q b")
  out, ok = sh_capture("ruby #{script} switch s1")
  assert(ok, "switch when on b in s1 failed: #{out}")
  assert(out.include?("🎯"), "expected fun emoji message:\n#{out}")
  assert(current_head == "b", "head should not change, got #{current_head}")

  out, ok = sh_capture("ruby #{script} switch nope")
  assert(!ok, "expected switch to unknown stack to fail")
  assert(out.include?("unknown stack"), "missing error message: #{out}")
end

def scenario_worktree_discovery(script)
  make_branch("a", "main", "a.txt", "a\n")
  # .stacks.yml lives at the main repo root only. It's git-ignored, so it does
  # not travel into a linked worktree — exactly the case the fallback targets.
  write_stacks("s:\n  - main\n  - a\n")
  sh_quiet("git checkout -q main")

  wt = File.expand_path("../wt-#{Process.pid}", Dir.pwd)
  FileUtils.rm_rf(wt)
  sh_quiet("git worktree add -q #{wt} a")

  Dir.chdir(wt) do
    assert(!File.exist?(".stacks.yml"), "precondition: .stacks.yml should not exist in worktree")
    out, ok = sh_capture("ruby #{script} status")
    assert(ok, "status in worktree failed: #{out}")
    assert(out.include?("stack: s"), "expected main-repo .stacks.yml to be discovered from worktree:\n#{out}")

    # A worktree-local file takes precedence over the main-repo fallback.
    write_stacks("local:\n  - main\n  - a\n")
    out, ok = sh_capture("ruby #{script} status")
    assert(ok, "status with worktree-local file failed: #{out}")
    assert(out.include?("stack: local"), "expected worktree-local .stacks.yml to win:\n#{out}")
  end
end

def scenario_push_mutually_exclusive(script)
  make_branch("a", "main", "a.txt", "a\n")
  write_stacks("s:\n  - main\n  - a\n")
  out, ok = sh_capture("ruby #{script} push --no-verify --some-verify")
  assert(!ok, "expected push --no-verify --some-verify to fail")
  assert(out.include?("mutually exclusive"), "missing error message:\n#{out}")
end

def run_test_suite
  script_path = File.expand_path(__FILE__)
  scratch = File.expand_path("./git-stacks-test-#{Process.pid}-#{Time.now.to_i}")
  if File.exist?(scratch)
    die("scratch path already exists: #{scratch}")
  end
  FileUtils.mkdir_p(scratch)
  warn "scratch dir: #{scratch}"

  start_dir = Dir.pwd
  runner = TestRunner.new(script_path, scratch)

  scenarios = {
    "happy_path"             => method(:scenario_happy_path),
    "rebase_default_is_current_branch" => method(:scenario_rebase_default_is_current_branch),
    "duplicate_branch"       => method(:scenario_duplicate_branch),
    "dry_run"                => method(:scenario_dry_run),
    "status"                 => method(:scenario_status),
    "diff"                   => method(:scenario_diff),
    "nav"                    => method(:scenario_nav),
    "last"                   => method(:scenario_last),
    "default_is_status"      => method(:scenario_default_is_status),
    "push_dry_run"           => method(:scenario_push_dry_run),
    "push_force"             => method(:scenario_push_force_updates_remote),
    "push_no_verify"         => method(:scenario_push_no_verify),
    "push_some_verify"       => method(:scenario_push_some_verify),
    "push_mutually_exclusive"=> method(:scenario_push_mutually_exclusive),
    "switch"                 => method(:scenario_switch),
    "worktree_discovery"     => method(:scenario_worktree_discovery),
  }

  scenarios.each do |name, m|
    runner.run(name) { |script| m.call(script) }
  end

  Dir.chdir(start_dir)

  warn ""
  warn "Summary:"
  runner.results.each do |name, status, msg|
    line = "  #{status == :pass ? 'PASS' : 'FAIL'}  #{name}"
    line += " — #{msg}" if msg
    warn line
  end

  if runner.all_passed?
    FileUtils.rm_rf(scratch)
    warn "all scenarios passed; scratch dir removed."
    exit 0
  else
    warn ""
    warn "failures left for inspection at: #{scratch}"
    exit 1
  end
end

dispatch(ARGV)
